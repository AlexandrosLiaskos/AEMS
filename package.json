{
  "name": "aems",
  "version": "1.0.0",
  "description": "Agentic Email Management System",
  "main": "main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "desktop": "node desktop-app.js",
    "build": "pkg . --targets node18-win-x64 --output dist/AEMS.exe",
    "build-all": "pkg desktop-app.js --targets node18-win-x64,node18-macos-x64,node18-linux-x64 --out-path dist",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "@langchain/community": "^0.3.51",
    "@langchain/openai": "^0.0.25",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-progress": "^1.1.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "dompurify": "^3.0.6",
    "dotenv": "^16.3.1",
    "dunder-proto": "^1.0.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.17.3",
    "express-validator": "^7.0.1",
    "googleapis": "^128.0.0",
    "helmet": "^7.1.0",
    "jsdom": "^26.1.0",
    "langchain": "^0.1.30",
    "lucide-react": "^0.540.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "openai": "^4.28.4",
    "p-finally": "^2.0.1",
    "passport": "^0.6.0",
    "passport-google-oauth20": "^2.0.0",
    "pdf-parse": "^1.1.1",
    "tailwind-merge": "^3.3.1",
    "uuid": "^9.0.1",
    "write-file-atomic": "^6.0.0",
    "xlsx": "^0.18.5"
  },
  "homepage": "./",
  "bin": {
    "aems": "./desktop-app.js"
  },
  "pkg": {
    "scripts": [
      "server.js",
      "desktop-app.js",
      "lib/**/*.js"
    ],
    "assets": [
      "public/**/*",
      "lib/**/*",
      "views/**/*",
      "logs/**/*",
      "data/**/*"
    ],
    "outputPath": "dist",
    "targets": [
      "node18-win-x64"
    ]
  }
}
