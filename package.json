{
  "name": "AEMS",
  "version": "1.0.0",
  "description": "Agentic Email Management System - Simple Node.js + JSON DB approach",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "echo 'No build process needed for this simple setup'",
    "test": "node tests/run-tests.js",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest tests/unit --verbose",
    "test:integration": "jest tests/integration --verbose",
    "test:quick": "jest --passWithNoTests",
    "test:debug": "jest --verbose --no-cache --runInBand",
    "test:ci": "jest --ci --coverage --watchAll=false"
  },
  "dependencies": {
    "@langchain/community": "^0.3.51",
    "@langchain/openai": "^0.0.25",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "dompurify": "^3.0.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.17.3",
    "express-validator": "^7.0.1",
    "googleapis": "^128.0.0",
    "helmet": "^7.1.0",
    "jsdom": "^23.0.1",
    "langchain": "^0.1.30",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "openai": "^4.28.4",
    "passport": "^0.6.0",
    "passport-google-oauth20": "^2.0.0",
    "pdf-parse": "^1.1.1",
    "uuid": "^9.0.1",
    "write-file-atomic": "^6.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@jest/globals": "^30.0.5",
    "jest": "^30.0.5",
    "nodemon": "^3.0.2",
    "supertest": "^7.1.4"
  },
  "keywords": [
    "email",
    "management",
    "gmail",
    "ai",
    "automation"
  ],
  "author": "",
  "license": "MIT",
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "lib/**/*.js",
      "server.js",
      "!lib/**/*.test.js",
      "!node_modules/**"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup/test-setup.js"
    ],
    "testTimeout": 30000
  }
}
