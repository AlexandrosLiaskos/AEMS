{
  "name": "aems",
  "version": "1.0.0",
  "description": "Agentic Email Management System",
  "main": "main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "electron": "electron .",
    "electron-dev": "AEMS_MODE=desktop electron .",
    "build": "electron-builder",
    "build-win": "electron-builder --win",
    "build-mac": "electron-builder --mac",
    "build-linux": "electron-builder --linux"
  },
  "dependencies": {
    "@langchain/community": "^0.3.51",
    "@langchain/openai": "^0.0.25",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "dompurify": "^3.0.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.17.3",
    "express-validator": "^7.0.1",
    "googleapis": "^128.0.0",
    "helmet": "^7.1.0",
    "langchain": "^0.1.30",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "openai": "^4.28.4",
    "passport": "^0.6.0",
    "passport-google-oauth20": "^2.0.0",
    "pdf-parse": "^1.1.1",
    "uuid": "^9.0.1",
    "write-file-atomic": "^6.0.0",
    "xlsx": "^0.18.5"
  },
  "homepage": "./",
  "devDependencies": {
    "electron": "^37.3.1",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.aems.desktop",
    "productName": "AEMS - Agentic Email Management System",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "server.js",
      "lib/**/*",
      "public/**/*",
      "node_modules/**/*",
      "package.json",
      "!node_modules/.cache",
      "!**/*.map"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
