# AEMS Environment Configuration
# Copy this file to .env and update with your actual values

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Environment (development, production, test)
NODE_ENV=development

# Server port
PORT=3001

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:3000

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Database type (json, sqlite)
DATABASE_TYPE=json

# Database path (for JSON files or SQLite database)
DATABASE_PATH=./data

# Database synchronization (for development only)
DATABASE_SYNCHRONIZE=true

# Database logging
DATABASE_LOGGING=false

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================

# JWT secret key (minimum 32 characters)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars

# JWT token expiration
JWT_EXPIRES_IN=7d

# Session secret for OAuth flows
SESSION_SECRET=your-session-secret-change-this-in-production

# CORS origins (comma-separated for multiple origins)
CORS_ORIGIN=http://localhost:3000

# =============================================================================
# GOOGLE OAUTH & GMAIL API
# =============================================================================

# Google OAuth credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# OAuth redirect URI
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# Gmail API scopes
GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.readonly

# Gmail API rate limiting (requests per minute)
GMAIL_RATE_LIMIT=15000

# =============================================================================
# OPENAI API CONFIGURATION
# =============================================================================

# OpenAI API key
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenAI model to use
OPENAI_MODEL=gpt-3.5-turbo

# Maximum tokens for AI responses
OPENAI_MAX_TOKENS=1000

# Temperature for AI responses (0-1, lower = more deterministic)
OPENAI_TEMPERATURE=0.1

# Request timeout in milliseconds
OPENAI_TIMEOUT=30000

# OpenAI rate limiting (requests per minute)
OPENAI_RATE_LIMIT=3000

# =============================================================================
# AI PROCESSING SETTINGS
# =============================================================================

# Enable AI processing features
ENABLE_AI_PROCESSING=true

# Classification confidence threshold (0-1)
CLASSIFICATION_CONFIDENCE_THRESHOLD=0.8

# Available classification categories (comma-separated)
CLASSIFICATION_CATEGORIES=invoice,receipt,newsletter,personal,business,support,marketing

# Data extraction confidence threshold (0-1)
EXTRACTION_CONFIDENCE_THRESHOLD=0.9

# Fields to extract from documents (comma-separated)
EXTRACTION_FIELDS=amount,date,vendor,invoice_number,tax,currency,due_date

# =============================================================================
# BACKUP CONFIGURATION
# =============================================================================

# Enable automatic backups
BACKUP_ENABLED=true

# Backup directory path
BACKUP_PATH=./backups

# Backup retention period in days
BACKUP_RETENTION_DAYS=30

# Backup schedule (cron format: minute hour day month weekday)
BACKUP_SCHEDULE=0 2 * * *

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

# Log level (error, warn, info, debug)
LOG_LEVEL=info

# Log file path (leave empty to disable file logging)
LOG_FILE=./logs/aems.log

# Enable console logging
LOG_CONSOLE=true

# Log format (json, simple)
LOG_FORMAT=simple

# =============================================================================
# PERFORMANCE & RATE LIMITING
# =============================================================================

# Maximum concurrent email processing
MAX_CONCURRENT_EMAILS=5

# Maximum concurrent data extractions
MAX_CONCURRENT_EXTRACTIONS=3

# Email batch processing size
BATCH_SIZE=10

# API rate limiting
API_RATE_LIMIT=1000
API_RATE_LIMIT_WINDOW=900000

# Cache settings
CACHE_TTL=300
CACHE_MAX_SIZE=1000

# =============================================================================
# NOTIFICATION SETTINGS
# =============================================================================

# Enable real-time notifications
ENABLE_NOTIFICATIONS=true

# WebSocket connection timeout
WEBSOCKET_TIMEOUT=30000

# Notification retention period in days
NOTIFICATION_RETENTION_DAYS=90

# =============================================================================
# MONITORING & METRICS
# =============================================================================

# Enable metrics collection
ENABLE_METRICS=true

# Metrics retention period in days
METRICS_RETENTION_DAYS=30

# Health check timeout in milliseconds
HEALTH_CHECK_TIMEOUT=5000

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================

# Enable GraphQL playground (development only)
GRAPHQL_PLAYGROUND=true

# Enable GraphQL introspection (development only)
GRAPHQL_INTROSPECTION=true

# Enable debug mode
DEBUG_MODE=false

# Hot reload for development
HOT_RELOAD=true

# =============================================================================
# PRODUCTION OVERRIDES
# =============================================================================
# Uncomment and modify these settings for production deployment

# NODE_ENV=production
# LOG_LEVEL=warn
# GRAPHQL_PLAYGROUND=false
# GRAPHQL_INTROSPECTION=false
# DATABASE_SYNCHRONIZE=false
# DEBUG_MODE=false
# HOT_RELOAD=false

# Production security settings
# JWT_EXPIRES_IN=1d
# CORS_ORIGIN=https://yourdomain.com
# FRONTEND_URL=https://yourdomain.com
# GOOGLE_REDIRECT_URI=https://yourdomain.com/api/auth/google/callback

# Production performance settings
# MAX_CONCURRENT_EMAILS=10
# CACHE_TTL=600
# API_RATE_LIMIT=2000