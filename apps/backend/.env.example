# AEMS Backend Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
NODE_ENV=development
PORT=8080
FRONTEND_URL=http://localhost:5173
SESSION_SECRET=your-super-secret-session-key-change-this-in-production
CORS_ORIGINS=http://localhost:5173
API_PREFIX=api
ENABLE_SWAGGER=true
LOG_LEVEL=info
TIMEZONE=UTC

# =============================================================================
# DATABASE SETTINGS
# =============================================================================
DATABASE_TYPE=json
DATABASE_PATH=data
DATABASE_SYNCHRONIZE=true
DATABASE_LOGGING=false
DATABASE_MAX_CONNECTIONS=10
DATABASE_ACQUIRE_TIMEOUT=60000
DATABASE_TIMEOUT=30000
DATABASE_BACKUP_ENABLED=true
DATABASE_BACKUP_INTERVAL=900000
DATABASE_BACKUP_RETENTION=30

# =============================================================================
# AUTHENTICATION SETTINGS
# =============================================================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=900000

# =============================================================================
# GOOGLE OAUTH2 SETTINGS
# =============================================================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:8080/api/auth/google/callback

# =============================================================================
# GMAIL API SETTINGS
# =============================================================================
GMAIL_CLIENT_ID=your-gmail-client-id
GMAIL_CLIENT_SECRET=your-gmail-client-secret
GMAIL_REDIRECT_URI=http://localhost:8080/api/auth/google/callback
GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.readonly,https://www.googleapis.com/auth/userinfo.profile,https://www.googleapis.com/auth/userinfo.email
GMAIL_QUOTA_LIMIT=1000000000
GMAIL_REQUESTS_PER_SECOND=100
GMAIL_BATCH_SIZE=50
GMAIL_SYNC_INTERVAL=300000
GMAIL_FULL_SYNC_INTERVAL=86400000
GMAIL_MAX_RETRIES=3
GMAIL_RETRY_DELAY=5000
GMAIL_WEBHOOK_URL=
GMAIL_PUBSUB_TOPIC=
GMAIL_PUBSUB_SUBSCRIPTION=

# =============================================================================
# AI SERVICES SETTINGS
# =============================================================================
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_MAX_TOKENS=1000
OPENAI_TEMPERATURE=0.3
OPENAI_TIMEOUT=30000
OPENAI_MAX_RETRIES=3
OPENAI_RETRY_DELAY=2000
AI_COST_TRACKING_ENABLED=true
AI_DAILY_COST_LIMIT=10
AI_MONTHLY_COST_LIMIT=100
AI_CLASSIFICATION_CONFIDENCE_THRESHOLD=0.7
AI_EXTRACTION_CONFIDENCE_THRESHOLD=0.8
AI_BATCH_PROCESSING_ENABLED=true
AI_BATCH_SIZE=5
AI_BATCH_TIMEOUT=60000
AI_CACHE_ENABLED=true
AI_CACHE_TTL=3600000
AI_FALLBACK_ENABLED=true
AI_FALLBACK_MODEL=gpt-3.5-turbo

# =============================================================================
# OPTIONAL SETTINGS
# =============================================================================

# Email Processing
EMAIL_PROCESSING_CONCURRENCY=5
EMAIL_PROCESSING_TIMEOUT=300000
EMAIL_ATTACHMENT_MAX_SIZE=25000000
EMAIL_ATTACHMENT_ALLOWED_TYPES=pdf,doc,docx,xls,xlsx,txt,csv,png,jpg,jpeg,gif

# Notification Settings
NOTIFICATION_ENABLED=true
NOTIFICATION_EMAIL_ENABLED=false
NOTIFICATION_EMAIL_FROM=noreply@aems.local
NOTIFICATION_EMAIL_SMTP_HOST=
NOTIFICATION_EMAIL_SMTP_PORT=587
NOTIFICATION_EMAIL_SMTP_USER=
NOTIFICATION_EMAIL_SMTP_PASS=

# Export Settings
EXPORT_MAX_RECORDS=10000
EXPORT_TIMEOUT=300000
EXPORT_FORMATS=xlsx,csv,json

# Health Check Settings
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_TIMEOUT=5000
HEALTH_CHECK_MEMORY_THRESHOLD=0.9
HEALTH_CHECK_DISK_THRESHOLD=0.9

# Monitoring Settings
METRICS_ENABLED=true
METRICS_PORT=9090
METRICS_PATH=/metrics

# Development Settings (only for development)
ENABLE_GRAPHQL_PLAYGROUND=true
ENABLE_GRAPHQL_INTROSPECTION=true
ENABLE_DEBUG_LOGGING=false